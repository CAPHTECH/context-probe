{
  "name": "context-probe",
  "version": "0.1.0",
  "description": "AI支援設計計測プラットフォームのCLI実装",
  "type": "module",
  "bin": {
    "context-probe": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "minimatch": "^10.0.1",
    "typescript": "^5.8.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
